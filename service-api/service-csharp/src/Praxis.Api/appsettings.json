{
  "ConnectionStrings": {
    "PraxisDatabase": "Host=service-postgresql;Port=5432;Database=praxis_db;Username=postgres;Password=postgres"
  },
  "Jwt": {
    "Issuer": "praxis.api",
    "Audience": "praxis.clients",
    "SecretKey": "CHANGE_THIS_SECRET_KEY_IN_DOCKER",
    "AccessTokenMinutes": 60
  },
  "Redis": {
    "ConnectionString": "service-redis:6379",
    "DashboardCacheKey": "praxis:dashboard:snapshot",
    "DashboardCacheMinutes": 5
  },
  "RabbitMq": {
    "HostName": "service-rabbitmq",
    "Port": 5672,
    "Username": "praxis",
    "Password": "praxis",
    "ExchangeName": "praxis.events",
    "QueueName": "praxis.worker.events"
  },
  "Seed": {
    "AdminFullName": "Praxis Administrator",
    "AdminEmail": "admin@praxis.local",
    "AdminPassword": "Admin@12345"
  },
  "OpenTelemetry": {
    "OtlpEndpoint": "http://service-otel-lgtm:4317"
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
      }
    }
  },
  "AllowedHosts": "*"
}
